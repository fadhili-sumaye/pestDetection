<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.PestDetection" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_green_light</item>
        <item name="colorOnPrimary">@color/primary_green_dark</item>
        <item name="colorPrimaryContainer">@color/primary_green_dark</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Background and Surface (Dark) -->
        <item name="android:windowBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">#000000</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
</resources>